# Flutter pod helper
load File.join(File.dirname(__FILE__), 'Flutter', 'podhelper.rb')

platform :ios, '15.0'
project 'Runner'

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      flutter_additional_ios_build_settings(target)
      target.build_configurations.each do |config|
        # 🎯 UYUMSUZLUK GİDERİLDİ: Yukarıdaki 15.0 ile burayı eşitledik
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
        
        # Kod imzalama ayarları (GitHub Actions için)
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        
        # 📸 EKSİK İZİNLER EKLENDİ (Kamera, Mikrofon, Galeri, Ses Tanıma)
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
          '$(inherited)',
          'PERMISSION_CAMERA=1',
          'PERMISSION_MICROPHONE=1',
          'PERMISSION_PHOTOS=1',
          'PERMISSION_SPEECH_RECOGNIZER=1' # 🎙️ İŞTE BURASI! Sesli komutların kilidi.
        ]
      end
    end
  end
end